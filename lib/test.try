class Expect {
    let actual;
    fn init(value) {
        this.actual = value;
    }
    fn toBe(expected) {
        assertEq(this.actual, expected, "toBe");
    }
    fn toNotBe(unexpected) {
        assertNeq(this.actual, unexpected, "toNotBe");
    }
    fn toBeCloseTo(expected, precision) {
        let prec = precision;
        if (prec == nil) prec = 2;
        let tolerance = 1;
        let i = 0;
        while (i < prec) {
            tolerance = tolerance / 10;
            i = i + 1;
        }
        let diff = this.actual - expected;
        if (diff < 0) diff = -diff;
        assert(diff <= tolerance, "toBeCloseTo");
    }
    fn toBeGreaterThan(expected) {
        assert(this.actual > expected, "toBeGreaterThan");
    }
    fn toBeLessThan(expected) {
        assert(this.actual < expected, "toBeLessThan");
    }
    fn toBeGreaterThanOrEqual(expected) {
        assert(this.actual >= expected, "toBeGreaterThanOrEqual");
    }
    fn toBeLessThanOrEqual(expected) {
        assert(this.actual <= expected, "toBeLessThanOrEqual");
    }
    fn toBeTrue() {
        assert(this.actual, "toBeTrue");
    }
    fn toBeFalse() {
        assert(!this.actual, "toBeFalse");
    }
    fn toBeNil() {
        assert(this.actual == nil, "toBeNil");
    }
    fn toThrow() {
        assertThrows(this.actual, "toThrow");
    }
}

let expect = fn(actual) {
    return Expect(actual);
};
