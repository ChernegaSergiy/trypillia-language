describe("JIT", fn() {
    it("compiles simple add after 50 calls", fn() {
        fn add(a, b) {
            return a + b;
        }
        let i = 0;
        while (i < 60) {
            assertEq(add(i, i + 1), i * 2 + 1);
            i = i + 1;
        }
    });

    it("compiles arithmetic chain after 50 calls", fn() {
        fn compute(x) {
            return (x * 2 + 10) / 2 - 5;
        }
        let i = 0;
        while (i < 60) {
            assertEq(compute(i), i);
            i = i + 1;
        }
    });

    it("compiles with bitwise after 50 calls", fn() {
        fn bitops(a, b) {
            let r = a & b;
            r = r | (a ^ b);
            r = r << 1;
            r = r >> 1;
            return r;
        }
        let i = 0;
        while (i < 60) {
            assertEq(bitops(i, i + 1), ((i & (i + 1)) | (i ^ (i + 1))) << 1 >> 1);
            i = i + 1;
        }
    });

    it("compiles with negation after 50 calls", fn() {
        fn run(x) {
            return -x;
        }
        let i = 0;
        while (i < 60) {
            assertEq(run(i), -i);
            i = i + 1;
        }
    });

    it("compiles if/else after 50 calls", fn() {
        fn run(x) {
            if (x == 0) return 1;
            return 0;
        }
        let i = 0;
        while (i < 60) {
            if (i == 0) {
                assertEq(run(i), 1);
            } else {
                assertEq(run(i), 0);
            }
            i = i + 1;
        }
    });
});
