describe("closures", fn() {
    it("basic closure", fn() {
        fn makeCounter(start) {
            let count = start;
            fn inner() {
                count = count + 1;
                return count;
            }
            return inner;
        }
        let counter = makeCounter(0);
        assertEq(counter(), 1);
        assertEq(counter(), 2);
        assertEq(counter(), 3);
    });

    it("multiple closures", fn() {
        fn makeCounter(start) {
            let count = start;
            fn inner() {
                count = count + 1;
                return count;
            }
            return inner;
        }
        let c1 = makeCounter(10);
        let c2 = makeCounter(100);
        assertEq(c1(), 11);
        assertEq(c2(), 101);
        assertEq(c1(), 12);
        assertEq(c2(), 102);
    });

    it("closure with params", fn() {
        fn makeAdder(x) {
            fn add(y) {
                return x + y;
            }
            return add;
        }
        let add5 = makeAdder(5);
        let add10 = makeAdder(10);
        assertEq(add5(3), 8);
        assertEq(add5(10), 15);
        assertEq(add10(1), 11);
    });

    it("nested closures", fn() {
        fn outer(x) {
            fn middle(y) {
                fn inner(z) {
                    return x + y + z;
                }
                return inner;
            }
            return middle;
        }
        assertEq(outer(1)(2)(3), 6);
    });

    it("closure upvalue modify", fn() {
        fn makeAccumulator() {
            let sum = 0;
            fn add(n) {
                sum = sum + n;
                return sum;
            }
            return add;
        }
        let acc = makeAccumulator();
        assertEq(acc(5), 5);
        assertEq(acc(3), 8);
        assertEq(acc(2), 10);
    });

    it("closure in list", fn() {
        fn makeMult(n) {
            fn mult(x) { return x * n; }
            return mult;
        }
        let fns = [makeMult(2), makeMult(3)];
        assertEq(fns[0](5), 10);
        assertEq(fns[1](5), 15);
    });

    it("closure over nested loops", fn() {
        fn makeCounter() {
            let i = 0;
            fn inc() {
                i = i + 1;
                return i;
            }
            return inc;
        }
        let c = makeCounter();
        let sum = 0;
        let j = 0;
        while (j < 5) {
            sum = sum + c();
            j = j + 1;
        }
        assertEq(sum, 15);
    });
});
