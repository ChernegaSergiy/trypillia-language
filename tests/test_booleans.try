describe("booleans", fn() {
    it("boolean values", fn() {
        assertEq(true, true);
        assertEq(false, false);
        assertNeq(true, false);
    });

    it("logical not", fn() {
        assertEq(!true, false);
        assertEq(!false, true);
        assertEq(!!true, true);
        assertEq(!!false, false);
    });

    it("equality", fn() {
        assertNeq(1, 2);
        assertEq(1, 1);
        assertNeq("a", "b");
        assertNeq(nil, true);

        let x = 42;
        assertEq(x, 42);
        assertNeq(x, 43);
    });

    it("comparison", fn() {
        assertEq(1 < 1, false);
        assertEq(2 < 1, false);
        assertEq(1 < 2, true);

        assertEq(1 > 1, false);
        assertEq(1 > 2, false);
        assertEq(2 > 1, true);

        assertEq(2 <= 1, false);
        assertEq(1 <= 1, true);
        assertEq(1 <= 2, true);

        assertEq(1 >= 2, false);
        assertEq(1 >= 1, true);
        assertEq(2 >= 1, true);
    });

    it("truthiness", fn() {
        if (nil) assert(false);
        if (false) assert(false);
        if (!true) assert(false);

        assert(0);
        assert(1);
        assert("");
        assert([]);
        assert({});
    });

    it("type coercion", fn() {
        assertNeq(1, true);
        assertNeq(0, false);
        assertNeq("", false);
        assertNeq(nil, false);
    });
});
