describe("classes", fn() {
    it("basic class", fn() {
        class Dog {
            let name;
            fn init(n) {
                this.name = n;
            }
            fn bark() {
                return this.name + " barks";
            }
        }
        let d = Dog("rex");
        assertEq(d.name, "rex");
        assertEq(d.bark(), "rex barks");
    });

    it("class method chaining", fn() {
        class Counter {
            let val;
            fn init(v) {
                this.val = v;
            }
            fn inc() {
                this.val = this.val + 1;
                return this.val;
            }
            fn get() {
                return this.val;
            }
        }
        let c = Counter(0);
        assertEq(c.get(), 0);
        assertEq(c.inc(), 1);
        assertEq(c.inc(), 2);
        assertEq(c.get(), 2);
    });

    it("class property set", fn() {
        class Box {
            let val;
            fn init(v) {
                this.val = v;
            }
        }
        let b = Box(10);
        b.val = 20;
        assertEq(b.val, 20);
    });

    it("inheritance", fn() {
        class Animal {
            let name;
            fn init(n) {
                this.name = n;
            }
            fn speak() {
                return this.name + " makes a sound";
            }
        }
        class Cat < Animal {
            fn init(n) {
                this.name = n;
            }
            fn speak() {
                return this.name + " meows";
            }
        }
        let a = Animal("generic");
        let c = Cat("whiskers");
        assertEq(a.speak(), "generic makes a sound");
        assertEq(c.speak(), "whiskers meows");
    });

    it("inherited method", fn() {
        class Animal {
            let name;
            fn init(n) {
                this.name = n;
            }
            fn getName() {
                return this.name;
            }
        }
        class Dog < Animal {
            fn init(n) {
                this.name = n;
            }
        }
        let d = Dog("buddy");
        assertEq(d.getName(), "buddy");
    });

    it("class with default arity", fn() {
        class Empty {
            fn init() {
            }
            fn greet() {
                return "hello";
            }
        }
        let e = Empty();
        assertEq(e.greet(), "hello");
    });

    it("class multiple instances", fn() {
        class Point {
            let x;
            let y;
            fn init(xv, yv) {
                this.x = xv;
                this.y = yv;
            }
        }
        let p1 = Point(1, 2);
        let p2 = Point(3, 4);
        assertEq(p1.x, 1);
        assertEq(p1.y, 2);
        assertEq(p2.x, 3);
        assertEq(p2.y, 4);
        p1.x = 10;
        assertEq(p1.x, 10);
        assertEq(p2.x, 3);
    });
});
