describe("lists", fn() {
    it("list literal", fn() {
        let lst = [1, 2, 3];
        assertEq(lst[0], 1);
        assertEq(lst[1], 2);
        assertEq(lst[2], 3);
    });

    it("list length", fn() {
        assertEq([].length(), 0);
        assertEq([1].length(), 1);
        assertEq([1, 2, 3].length(), 3);
    });

    it("list index set", fn() {
        let lst = [1, 2, 3];
        lst[0] = 10;
        lst[2] = 30;
        assertEq(lst[0], 10);
        assertEq(lst[1], 2);
        assertEq(lst[2], 30);
    });

    it("list nested", fn() {
        let nested = [1, [2, 3], 4];
        assertEq(nested[0], 1);
        assertEq(nested[1][0], 2);
        assertEq(nested[1][1], 3);
        assertEq(nested[2], 4);
    });

    it("list mixed types", fn() {
        let lst = [1, "hello", true, nil, [5]];
        assertEq(lst[0], 1);
        assertEq(lst[1], "hello");
        assertEq(lst[2], true);
        assertEq(lst[3], nil);
        assertEq(lst[4][0], 5);
    });

    it("list expression", fn() {
        let lst = [1 + 2, 3 * 4, 10 - 5];
        assertEq(lst[0], 3);
        assertEq(lst[1], 12);
        assertEq(lst[2], 5);
    });
});
