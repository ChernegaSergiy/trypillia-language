fn testListLiteral() {
    let lst = [1, 2, 3];
    if (lst[0] != 1) print("FAIL: lst[0] != 1");
    if (lst[1] != 2) print("FAIL: lst[1] != 2");
    if (lst[2] != 3) print("FAIL: lst[2] != 3");
}

fn testListLength() {
    if ([].length() != 0) print("FAIL: empty list length");
    if ([1].length() != 1) print("FAIL: single list length");
    if ([1, 2, 3].length() != 3) print("FAIL: three list length");
}

fn testListIndexSet() {
    let lst = [1, 2, 3];
    lst[0] = 10;
    lst[2] = 30;
    if (lst[0] != 10) print("FAIL: lst[0] after set");
    if (lst[1] != 2) print("FAIL: lst[1] unchanged");
    if (lst[2] != 30) print("FAIL: lst[2] after set");
}

fn testListNested() {
    let nested = [1, [2, 3], 4];
    if (nested[0] != 1) print("FAIL: nested[0]");
    if (nested[1][0] != 2) print("FAIL: nested[1][0]");
    if (nested[1][1] != 3) print("FAIL: nested[1][1]");
    if (nested[2] != 4) print("FAIL: nested[2]");
}

fn testListMixedTypes() {
    let lst = [1, "hello", true, nil, [5]];
    if (lst[0] != 1) print("FAIL: mixed[0]");
    if (lst[1] != "hello") print("FAIL: mixed[1]");
    if (lst[2] != true) print("FAIL: mixed[2]");
    if (lst[3] != nil) print("FAIL: mixed[3]");
    if (lst[4][0] != 5) print("FAIL: mixed[4][0]");
}

fn testListExpression() {
    let lst = [1 + 2, 3 * 4, 10 - 5];
    if (lst[0] != 3) print("FAIL: expr[0]");
    if (lst[1] != 12) print("FAIL: expr[1]");
    if (lst[2] != 5) print("FAIL: expr[2]");
}

testListLiteral();
testListLength();
testListIndexSet();
testListNested();
testListMixedTypes();
testListExpression();

print("Lists OK");
print("ALL TESTS PASSED");
