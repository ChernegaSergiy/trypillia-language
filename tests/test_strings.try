fn testStringLiteral() {
    if ("hello" != "hello") print("FAIL: string literal");
    if ("hello" == "world") print("FAIL: string literal eq wrong");
}

fn testStringConcat() {
    if ("foo" + "bar" != "foobar") print("FAIL: foo+bar != foobar");
    if ("" + "a" != "a") print("FAIL: empty + a");
    if ("a" + "" != "a") print("FAIL: a + empty");
    if ("" + "" != "") print("FAIL: empty + empty");
    if ("he" + "llo" != "hello") print("FAIL: he+llo != hello");
}

fn testStringLength() {
    if ("hello".length() != 5) print("FAIL: hello length != 5");
    if ("".length() != 0) print("FAIL: empty length != 0");
    if ("abc".length() != 3) print("FAIL: abc length != 3");
}

fn testStringIndex() {
    if ("hello"[0] != "h") print("FAIL: hello[0] != h");
    if ("hello"[1] != "e") print("FAIL: hello[1] != e");
    if ("hello"[4] != "o") print("FAIL: hello[4] != o");
    if ("abc"[2] != "c") print("FAIL: abc[2] != c");
}

fn testStringComparison() {
    if ("abc" == "xyz") print("FAIL: abc == xyz");
    if ("abc" != "abc") print("FAIL: abc != abc");
    if ("hello" == "Hello") print("FAIL: hello == Hello");
}

fn testStringMixed() {
    let s = "Hello, " + "World!";
    if (s.length() != 13) print("FAIL: Hello World length");
    if (s[0] != "H") print("FAIL: Hello World[0]");
    if (s[12] != "!") print("FAIL: Hello World[12]");
}

testStringLiteral();
testStringConcat();
testStringLength();
testStringIndex();
testStringComparison();
testStringMixed();

print("Strings OK");
print("ALL TESTS PASSED");
