describe("strings", fn() {
    it("string literal", fn() {
        assertEq("hello", "hello");
        assertNeq("hello", "world");
    });

    it("string concat", fn() {
        assertEq("foo" + "bar", "foobar");
        assertEq("" + "a", "a");
        assertEq("a" + "", "a");
        assertEq("" + "", "");
        assertEq("he" + "llo", "hello");
    });

    it("string length", fn() {
        assertEq("hello".length(), 5);
        assertEq("".length(), 0);
        assertEq("abc".length(), 3);
    });

    it("string index", fn() {
        assertEq("hello"[0], "h");
        assertEq("hello"[1], "e");
        assertEq("hello"[4], "o");
        assertEq("abc"[2], "c");
    });

    it("string comparison", fn() {
        assertNeq("abc", "xyz");
        assertEq("abc", "abc");
        assertNeq("hello", "Hello");
    });

    it("string mixed", fn() {
        let s = "Hello, " + "World!";
        assertEq(s.length(), 13);
        assertEq(s[0], "H");
        assertEq(s[12], "!");
    });
});
