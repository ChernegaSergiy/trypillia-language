fn testAssertPasses() {
    assert(1 == 1);
}

fn testAssertEqWithNumbers() {
    assertEq(2 + 2, 4);
}

fn testAssertEqWithStrings() {
    assertEq("hello" + " world", "hello world");
}

fn testAssertEqWithBool() {
    assertEq(5 > 3, true);
}

fn testAssertNeqPasses() {
    assertNeq(1, 2);
    assertNeq("a", "b");
    assertNeq(true, false);
}

fn testAssertThrowsPasses() {
    assertThrows(fn () {
        let list = [1];
        let x = list[100];
    });
}

testAssertPasses();
testAssertEqWithNumbers();
testAssertEqWithStrings();
testAssertEqWithBool();
testAssertNeqPasses();
testAssertThrowsPasses();

print("Assert framework OK");
print("ALL TESTS PASSED");
