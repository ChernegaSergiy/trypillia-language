describe("assert framework", fn() {
    it("assert passes", fn() {
        assert(1 == 1);
    });

    it("assertEq with numbers", fn() {
        assertEq(2 + 2, 4);
    });

    it("assertEq with strings", fn() {
        assertEq("hello" + " world", "hello world");
    });

    it("assertEq with bool", fn() {
        assertEq(5 > 3, true);
    });

    it("assertNeq passes", fn() {
        assertNeq(1, 2);
        assertNeq("a", "b");
        assertNeq(true, false);
    });

    it("assertThrows passes", fn() {
        assertThrows(fn () {
            let list = [1];
            let x = list[100];
        });
    });

    it("load lib/test.try", fn() {
        load "lib/test.try";
        assert(expect != nil, "expect was defined");
    });

    it("expect toBe", fn() {
        load "lib/test.try";
        expect(2 + 2).toBe(4);
    });

    it("expect toNotBe", fn() {
        load "lib/test.try";
        expect(2 + 2).toNotBe(5);
    });

    it("expect toBeTrue", fn() {
        load "lib/test.try";
        expect(1 == 1).toBeTrue();
    });

    it("expect toBeFalse", fn() {
        load "lib/test.try";
        expect(1 == 2).toBeFalse();
    });

    it("expect toBeNil", fn() {
        load "lib/test.try";
        expect(nil).toBeNil();
    });

    it("expect toThrow", fn() {
        load "lib/test.try";
        expect(fn () {
            let list = [1];
            let x = list[100];
        }).toThrow();
    });

    it("expect toBeCloseTo", fn() {
        load "lib/test.try";
        expect(0.1 + 0.2).toBeCloseTo(0.3, 2);
    });

    it("expect toBeGreaterThan", fn() {
        load "lib/test.try";
        expect(5).toBeGreaterThan(3);
    });

    it("expect toBeLessThan", fn() {
        load "lib/test.try";
        expect(3).toBeLessThan(5);
    });

    it("expect toBeGreaterThanOrEqual", fn() {
        load "lib/test.try";
        expect(5).toBeGreaterThanOrEqual(5);
        expect(6).toBeGreaterThanOrEqual(5);
    });

    it("expect toBeLessThanOrEqual", fn() {
        load "lib/test.try";
        expect(5).toBeLessThanOrEqual(5);
        expect(3).toBeLessThanOrEqual(5);
    });

    it("expect toHaveLength on list", fn() {
        load "lib/test.try";
        expect([1, 2, 3]).toHaveLength(3);
    });

    it("expect toHaveLength on string", fn() {
        load "lib/test.try";
        expect("hello").toHaveLength(5);
    });

    it("expect toContain on list", fn() {
        load "lib/test.try";
        expect([1, 2, 3]).toContain(2);
    });

    it("expect toMatch", fn() {
        load "lib/test.try";
        expect("hello world").toMatch("hello");
    });

    it("expect toBeDefined", fn() {
        load "lib/test.try";
        expect(42).toBeDefined();
    });

    it("xit skips test", fn() {
        xit("skipped", fn() {
            assert(false);
        });
    });
});
