describe("arithmetic", fn() {
    it("addition", fn() {
        assertEq(1 + 1, 2);
        assertEq(0 + 0, 0);
        assertEq(-1 + 1, 0);
        assertEq(100 + 200, 300);
        assertEq(1.5 + 2.5, 4);
    });

    it("subtraction", fn() {
        assertEq(5 - 3, 2);
        assertEq(1 - 1, 0);
        assertEq(3 - 5, -2);
        assertEq(0 - 10, -10);
    });

    it("multiplication", fn() {
        assertEq(2 * 3, 6);
        assertEq(0 * 5, 0);
        assertEq(-2 * 3, -6);
        assertEq(10 * 10, 100);
    });

    it("division", fn() {
        assertEq(10 / 2, 5);
        assertEq(7 / 2, 3.5);
        assertEq(0 / 5, 0);
        assertEq(-10 / 2, -5);
    });

    it("modulo", fn() {
        assertEq(10 % 3, 1);
        assertEq(10 % 5, 0);
        assertEq(7 % 10, 7);
        assertEq(0 % 5, 0);
    });

    it("negation", fn() {
        assertEq(-5, -5);
        assertEq(-(-10), 10);
        assertEq(-0, 0);
    });

    it("operator precedence", fn() {
        assertEq(1 + 2 * 3, 7);
        assertEq((1 + 2) * 3, 9);
        assertEq(10 - 5 - 2, 3);
        assertEq(10 / 2 * 3, 15);
        assertEq(10 + 5 % 3, 12);
    });

    it("compound expression", fn() {
        let x = 1;
        x = x + 1;
        assertEq(x, 2);

        let y = 10;
        y = y - 3;
        assertEq(y, 7);

        let z = 2;
        z = z * 5;
        assertEq(z, 10);

        let w = 20;
        w = w / 4;
        assertEq(w, 5);
    });
});
