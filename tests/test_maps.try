describe("maps", fn() {
    it("map literal", fn() {
        let map = {"a": 1, "b": 2, "c": 3};
        assertEq(map["a"], 1);
        assertEq(map["b"], 2);
        assertEq(map["c"], 3);
    });

    it("map length", fn() {
        let empty = {};
        let map = {"a": 1, "b": 2};
        assertEq(empty.keys().length(), 0);
        assertEq(map.keys().length(), 2);
    });

    it("map set", fn() {
        let map = {"a": 1};
        map["b"] = 2;
        map["a"] = 10;
        assertEq(map["a"], 10);
        assertEq(map["b"], 2);
    });

    it("map missing key", fn() {
        let map = {"a": 1};
        assertEq(map["x"], nil);
    });

    it("map keys", fn() {
        let map = {"x": 10, "y": 20};
        let keys = map.keys();
        let foundX = false;
        let foundY = false;
        let i = 0;
        while (i < keys.length()) {
            if (keys[i] == "x") foundX = true;
            if (keys[i] == "y") foundY = true;
            i = i + 1;
        }
        assert(foundX);
        assert(foundY);
    });

    it("map values", fn() {
        let map = {"x": 10, "y": 20};
        let vals = map.values();
        let found10 = false;
        let found20 = false;
        let i = 0;
        while (i < vals.length()) {
            if (vals[i] == 10) found10 = true;
            if (vals[i] == 20) found20 = true;
            i = i + 1;
        }
        assert(found10);
        assert(found20);
    });
});
