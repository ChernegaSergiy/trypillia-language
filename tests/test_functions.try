describe("functions", fn() {
    it("simple function", fn() {
        fn add(a, b) {
            return a + b;
        }
        assertEq(add(3, 4), 7);
        assertEq(add(-1, 1), 0);
    });

    it("multiple returns", fn() {
        fn identity(x) {
            return x;
        }
        assertEq(identity(42), 42);
        assertEq(identity("hi"), "hi");
        assertEq(identity(true), true);
        assertEq(identity(nil), nil);
    });

    it("early return", fn() {
        fn findFirst(arr, target) {
            let i = 0;
            while (i < arr.length()) {
                if (arr[i] == target) return i;
                i = i + 1;
            }
            return -1;
        }
        let arr = [10, 20, 30, 40, 50];
        assertEq(findFirst(arr, 30), 2);
        assertEq(findFirst(arr, 99), -1);
    });

    it("recursion", fn() {
        fn factorial(n) {
            if (n <= 1) return 1;
            return n * factorial(n - 1);
        }
        assertEq(factorial(5), 120);
        assertEq(factorial(10), 3628800);
    });

    it("direct recursion", fn() {
        fn sumTo(n) {
            if (n <= 0) return 0;
            return n + sumTo(n - 1);
        }
        assertEq(sumTo(10), 55);
    });

    it("function in list", fn() {
        fn double(x) { return x * 2; }
        fn triple(x) { return x * 3; }
        let fns = [double, triple];
        assertEq(fns[0](5), 10);
        assertEq(fns[1](5), 15);
    });

    it("function as arg", fn() {
        fn apply(f, x) { return f(x); }
        fn inc(x) { return x + 1; }
        assertEq(apply(inc, 5), 6);
    });
});
