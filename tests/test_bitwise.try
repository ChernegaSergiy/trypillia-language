describe("bitwise", fn() {
    it("and", fn() {
        assertEq(1 & 3, 1);
        assertEq(0 & 5, 0);
        assertEq(7 & 3, 3);
        assertEq(255 & 15, 15);
    });

    it("or", fn() {
        assertEq(1 | 2, 3);
        assertEq(0 | 5, 5);
        assertEq(8 | 4, 12);
        assertEq(1 | 1, 1);
    });

    it("xor", fn() {
        assertEq(1 ^ 3, 2);
        assertEq(1 ^ 1, 0);
        assertEq(5 ^ 3, 6);
        assertEq(255 ^ 0, 255);
    });

    it("not", fn() {
        assertEq(~1, -2);
        assertEq(~0, -1);
        assertEq(~-1, 0);
        assertEq(~255, -256);
    });

    it("shift left", fn() {
        assertEq(1 << 2, 4);
        assertEq(0 << 5, 0);
        assertEq(3 << 3, 24);
        assertEq(1 << 10, 1024);
    });

    it("shift right", fn() {
        assertEq(8 >> 1, 4);
        assertEq(16 >> 2, 4);
        assertEq(1 >> 1, 0);
        assertEq(1024 >> 10, 1);
    });

    it("combined", fn() {
        assertEq((1 & 3) | (2 << 1), 5);
        assertEq(~(255 ^ 15), -241);
    });
});
