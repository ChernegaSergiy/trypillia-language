describe("variables", fn() {
    it("let decl", fn() {
        let x = 10;
        assertEq(x, 10);
        x = 20;
        assertEq(x, 20);
    });

    it("multiple decl", fn() {
        let a = 1;
        let b = 2;
        let c = 3;
        assertEq(a + b + c, 6);
    });

    it("compound assign", fn() {
        let x = 10;
        x = x + 5;
        assertEq(x, 15);
        x = x - 3;
        assertEq(x, 12);
        x = x * 2;
        assertEq(x, 24);
        x = x / 4;
        assertEq(x, 6);
    });

    it("closure capture", fn() {
        let globalVar = 42;
        fn getGlobal() {
            return globalVar;
        }
        assertEq(getGlobal(), 42);
    });

    it("block scope", fn() {
        let x = 1;
        {
            let x = 2;
            assertEq(x, 2);
        }
        assertEq(x, 1);
    });

    it("swap", fn() {
        let a = 1;
        let b = 2;
        let tmp = a;
        a = b;
        b = tmp;
        assertEq(a, 2);
        assertEq(b, 1);
    });

    it("uninitialized", fn() {
        let x;
        assertEq(x, nil);
        x = 5;
        assertEq(x, 5);
    });
});
