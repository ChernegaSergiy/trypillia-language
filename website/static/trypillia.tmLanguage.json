{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Trypillia",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "match": "//.*",
          "name": "comment.line.double-slash.trypillia"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.trypillia",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.trypillia",
          "match": "\\\\."
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.trypillia",
          "match": "\\b(if|else|while|do|for|in|return|break|continue|switch|case|default)\\b"
        },
        {
          "name": "keyword.declaration.trypillia",
          "match": "\\b(class|fn|let|const|abstract|interface|trait|implements)\\b"
        },
        {
          "name": "storage.modifier.trypillia",
          "match": "\\b(public|private|protected|static|virtual|override)\\b"
        },
        {
          "name": "keyword.other.trypillia",
          "match": "\\b(load|destroy|using)\\b"
        },
        {
          "name": "constant.language.trypillia",
          "match": "\\b(true|false|nil)\\b"
        },
        {
          "name": "variable.language.trypillia",
          "match": "\\b(this|super)\\b"
        },
        {
          "name": "support.function.trypillia",
          "match": "\\b(print)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "name": "entity.name.function.trypillia"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.trypillia",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.trypillia",
          "match": "(\\+|-|\\*|/|%|\\+\\+|--|\\+=|-=|\\*=|/=|==|=>|=|!=|<|<=|>|>=|::|&&|\\|\\||&|\\||\\^|~|<<|>>)"
        }
      ]
    }
  },
  "scopeName": "source.trypillia"
}
